# Copy this file to ".env" and fill in what you have.
# Financier runs with NONE of these set (it falls back to a mock LLM + mock
# market data so you can demo offline). Add credentials to use real models.

# ===== Primary backend: AWS Bedrock (Claude via your AWS account) =====
# Easiest path: run `aws configure` so credentials live in ~/.aws/credentials
# and you can leave the two keys below blank. Otherwise set them here.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Only for temporary credentials (SSO / assumed role):
AWS_SESSION_TOKEN=
# Region where you enabled Claude model access in the Bedrock console:
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# ===== Alternative LLM backends (optional) =====
# Anthropic Claude direct API — https://console.anthropic.com/
ANTHROPIC_API_KEY=
# Google Gemini — https://aistudio.google.com/
GOOGLE_API_KEY=

# ===== Market data (optional) =====
# yfinance needs no key; Alpha Vantage is an optional fallback source.
ALPHA_VANTAGE_API_KEY=
